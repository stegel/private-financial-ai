# Private Financial AI - Git Ignore

# =============================================================================
# SECRETS - NEVER COMMIT THESE
# =============================================================================
config/providers/providers.yaml
config/*.conf
!config/*.example
!config/providers/*.example

# Env files anywhere in the tree
.env
.env.*
**/.env
**/.env.*

# Private key / certificate files
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer

# User's secrets directory (if stored inside repo)
secrets/

# =============================================================================
# GENERATED USER DATA
# =============================================================================
CHECKPOINT.md
CLAUDE_LITE.md

# Database
vault/
*.db
*.db-journal
*.db-wal
*.db-shm

# =============================================================================
# PYTHON
# =============================================================================
venv/
.venv/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
pip-log.txt
pip-delete-this-directory.txt
.python-version
.pytest_cache/
.coverage
htmlcov/

# =============================================================================
# NODE (if JS tooling is ever added)
# =============================================================================
node_modules/
npm-debug.log*
yarn-error.log*

